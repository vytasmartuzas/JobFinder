# Copy to .env and fill in. .env is gitignored.

# SQLite database location (v1). Swap for a Postgres URL in v2.
JOBFINDER_DATABASE_URL=sqlite:///./data/jobfinder.db

# Anthropic API key for CV tailoring (added in build step 4).
# ANTHROPIC_API_KEY=

# Where rendered CVs / cover letters are written (added in build step 3).
JOBFINDER_GENERATED_DIR=./generated
